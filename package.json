{
  "name": "medirecord",
  "type": "module",
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "dev:backend": "cd src/backend && npm run dev",
    "dev:frontend": "cd src/frontend && npm run dev",
    "start:backend": "cd src/backend && npm start",
    "start:frontend": "cd src/frontend && npm run dev",
    "install:all": "cd src/backend && npm install && cd ../frontend && npm install"
  }
}
